{
  "name": "jobvault-generation-service",
  "version": "1.0.0",
  "private": true,
  "description": "Generates .docx CV and cover letter documents for the JobVault pipeline",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --require tsconfig-paths/register src/index.ts",
    "lint": "eslint src --ext .ts",
    "build:templates": "node scripts/build-cv-template.js && node scripts/build-cl-template.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "adm-zip": "^0.5.17",
    "docx": "^9.7.1",
    "docxtemplater": "^3.59.0",
    "express": "^4.21.0",
    "pizzip": "^3.1.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
